{
  "name": "supersynth",
  "version": "0.1.5",
  "description": "High-performance audio synthesis for Node/Bun/Deno via native Rust bindings",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "supersynth.node",
    "supersynth.*.node"
  ],
  "scripts": {
    "build:native": "cd native && cargo build --release && cp target/release/libsupersynth_native.dylib ../supersynth.node 2>/dev/null || cp target/release/libsupersynth_native.so ../supersynth.node 2>/dev/null",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:native && npm run build:ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js",
    "test:rust": "cd native && cargo test",
    "bench": "node --import tsx bench/oscillators.bench.ts",
    "bench:realtime": "node --import tsx bench/realtime.bench.ts",
    "example:tone": "node --import tsx examples/tone.ts",
    "example:chord": "node --import tsx examples/chord.ts",
    "example:midi": "node --import tsx examples/midi-file.ts",
    "example:midi:piano": "node --import tsx examples/midi-piano.ts",
    "example:midi:organ": "node --import tsx examples/midi-organ.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analyze": "node --import tsx scripts/analyze-comparison.ts",
    "analyze:bwv539": "node --import tsx scripts/analyze-comparison.ts --reference '/Users/jddubois/Downloads/Preludes and Fugues/BWV0539i.m4a' --midi http://www.jsbach.net/midi/bwv539.mid"
  },
  "keywords": [
    "audio",
    "synthesis",
    "synth",
    "sound",
    "native",
    "rust",
    "midi",
    "dsp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jddubois/supersynth.git"
  },
  "homepage": "https://github.com/jddubois/supersynth#readme",
  "bugs": {
    "url": "https://github.com/jddubois/supersynth/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "midi-file": "^1.2.4",
    "node-web-audio-api": "^1.0.9",
    "tinybench": "^3.1.1",
    "ts-jest": "^29.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "web-audio-api": "^1.2.0"
  }
}
